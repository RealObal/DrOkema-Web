{
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://drokema.com/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "www.drokema.com"
        }
      ]
    }
  ]
}
